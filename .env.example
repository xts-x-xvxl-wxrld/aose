OPENAI_AGENT_MODEL=gpt-5.4-mini

# Frontend dev defaults
FRONTEND_PORT=5173
VITE_API_BASE_URL=/api/v1
VITE_DEV_PROXY_TARGET=http://api:8000

# Backend app
APP_ENV=development
DATABASE_ECHO=false
AUTH_MODE=fake

# Docker-first Postgres defaults
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agentic_ose
POSTGRES_TEST_DB=agentic_ose_test
POSTGRES_USER=agentic
POSTGRES_PASSWORD=agentic
DATABASE_URL=postgresql+asyncpg://agentic:agentic@postgres:5432/agentic_ose
TEST_DATABASE_URL=postgresql+psycopg://agentic:agentic@postgres:5432/agentic_ose_test
TENANT_SELF_SERVE_CREATION_ENABLED=true

# Fake auth for local development
FAKE_AUTH_ENABLED=true
FAKE_AUTH_USER_ID=user_dev
FAKE_AUTH_SUBJECT=dev-user
FAKE_AUTH_EMAIL=dev@agentic-ose.local
FAKE_AUTH_DISPLAY_NAME=Local Dev User
FAKE_AUTH_TENANT_ID=tenant_dev
FAKE_AUTH_TENANT_NAME=Local Dev Tenant
FAKE_AUTH_MEMBERSHIP_ROLE=owner

# Zitadel auth for API-first backend mode
ZITADEL_ISSUER=https://aose-authz-qirgym.ch1.zitadel.cloud
ZITADEL_AUDIENCE=366874018701128501
ZITADEL_JWKS_URI=https://aose-authz-qirgym.ch1.zitadel.cloud/oauth/v2/keys
ZITADEL_JWT_ALGORITHMS=RS256

# Phase 3 provider placeholders
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
GOOGLE_LOCAL_PLACES_API_KEY=
GOOGLE_LOCAL_PLACES_BASE_URL=https://places.googleapis.com
FINDYMAIL_API_KEY=
FINDYMAIL_BASE_URL=https://app.findymail.com
TOMBA_API_KEY=
TOMBA_API_SECRET=
TOMBA_BASE_URL=https://api.tomba.io
